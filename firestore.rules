rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Classes Collection
    match /classes/{classId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(classId);
    }

    // Books Collection
    match /books/{bookId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(bookId);
    }

    // Members Collection
    match /members/{memberId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(memberId);
    }

    // Loans Collection
    match /loans/{loanId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(loanId);
    }

    // Config Collection
    match /config/{configDoc} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(configDoc);
    }

    // Templates Collection
    match /templates/{templateId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(templateId);
    }
  }
}
